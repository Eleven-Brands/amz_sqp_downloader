# Pasta local para Chrome profile, logs e downloads temporarios.
# Padrao: C:\SQP -- altere se quiser usar outro caminho.
SQP_LOCAL_DIR=C:\SQP

# Caminho absoluto para o service account JSON do BigQuery.
# Padrao: irmao desta pasta (return_badge_predictor/service_account.json).
# So precisa definir se o service account estiver em outro lugar.
# SQP_SERVICE_ACCOUNT=C:\caminho\para\service_account.json

# Credenciais Gmail para notificacoes por e-mail (opcional).
# GMAIL_FROM=seu@email.com
# GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
# NOTIFY_EMAIL=destinatario@email.com

# API key do ClickUp para notificacoes no canal #teste-automate.
CLICKUP_API_KEY=pk_xxxxxxxx_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
